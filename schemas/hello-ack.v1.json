{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HelloAck v1",
  "description": "Handshake acknowledgement sent by the daemon after protocol negotiation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "accepted_protocol_version",
    "accepted_schema_version",
    "daemon_version",
    "policy_mapping"
  ],
  "properties": {
    "accepted_protocol_version": {
      "type": "string",
      "enum": ["v1"]
    },
    "accepted_schema_version": {
      "type": "string",
      "minLength": 1
    },
    "daemon_version": {
      "type": "string",
      "minLength": 1
    },
    "policy_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p1", "p2"],
      "properties": {
        "p1": {
          "type": "string",
          "minLength": 1
        },
        "p2": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "config": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  }
}
