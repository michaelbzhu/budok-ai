{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Event v2",
  "description": "Standard telemetry event emitted by the mod or daemon.",
  "type": "object",
  "additionalProperties": false,
  "required": ["match_id", "event"],
  "properties": {
    "match_id": {
      "type": "string",
      "minLength": 1
    },
    "event": {
      "type": "string",
      "enum": [
        "MatchStarted",
        "TurnRequested",
        "DecisionReceived",
        "DecisionApplied",
        "DecisionFallback",
        "MatchEnded",
        "ReplaySaved",
        "ReplayStarted",
        "ReplayEnded",
        "Error"
      ]
    },
    "turn_id": {
      "type": "integer",
      "minimum": 0
    },
    "player_id": {
      "type": "string",
      "minLength": 1
    },
    "fallback_reason": {
      "type": "string",
      "enum": [
        "timeout",
        "disconnect",
        "malformed_output",
        "illegal_output",
        "stale_response"
      ]
    },
    "latency_ms": {
      "type": "integer",
      "minimum": 0
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
