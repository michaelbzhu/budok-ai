{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DecisionRequest v2",
  "description": "Canonical turn request emitted by the mod at an actionable decision point.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "match_id",
    "turn_id",
    "player_id",
    "deadline_ms",
    "state_hash",
    "legal_actions_hash",
    "decision_type",
    "observation",
    "legal_actions"
  ],
  "properties": {
    "match_id": {
      "type": "string",
      "minLength": 1
    },
    "turn_id": {
      "type": "integer",
      "minimum": 0
    },
    "player_id": {
      "type": "string",
      "minLength": 1
    },
    "deadline_ms": {
      "type": "integer",
      "minimum": 1
    },
    "state_hash": {
      "type": "string",
      "minLength": 1
    },
    "legal_actions_hash": {
      "type": "string",
      "minLength": 1
    },
    "decision_type": {
      "type": "string",
      "enum": ["turn_action"]
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tick",
        "frame",
        "active_player",
        "fighters",
        "objects",
        "stage",
        "history"
      ],
      "properties": {
        "tick": {
          "type": "integer",
          "minimum": 0
        },
        "frame": {
          "type": "integer",
          "minimum": 0
        },
        "active_player": {
          "type": "string",
          "minLength": 1
        },
        "fighters": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "character",
              "hp",
              "max_hp",
              "meter",
              "burst",
              "position",
              "velocity",
              "facing",
              "current_state",
              "combo_count",
              "blockstun",
              "hitlag",
              "state_interruptable",
              "can_feint",
              "grounded"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "character": {
                "type": "string",
                "minLength": 1
              },
              "hp": {
                "type": "integer"
              },
              "max_hp": {
                "type": "integer",
                "minimum": 1
              },
              "meter": {
                "type": "integer",
                "minimum": 0
              },
              "burst": {
                "type": "integer",
                "minimum": 0
              },
              "position": {
                "$ref": "#/$defs/vector2"
              },
              "velocity": {
                "$ref": "#/$defs/vector2"
              },
              "facing": {
                "type": "string",
                "minLength": 1
              },
              "current_state": {
                "type": "string",
                "minLength": 1
              },
              "combo_count": {
                "type": "integer",
                "minimum": 0
              },
              "blockstun": {
                "type": "integer",
                "minimum": 0
              },
              "hitlag": {
                "type": "integer",
                "minimum": 0
              },
              "state_interruptable": {
                "type": "boolean"
              },
              "can_feint": {
                "type": "boolean"
              },
              "grounded": {
                "type": "boolean"
              },
              "air_actions_remaining": {
                "type": "integer",
                "minimum": 0
              },
              "feints_remaining": {
                "type": "integer",
                "minimum": 0
              },
              "initiative": {
                "type": "boolean"
              },
              "sadness": {
                "type": "integer",
                "minimum": 0
              },
              "wakeup_throw_immune": {
                "type": "boolean"
              },
              "combo_proration": {
                "type": "number"
              },
              "character_data": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "objects": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["type", "position"],
            "properties": {
              "type": {
                "type": "string",
                "minLength": 1
              },
              "category": {
                "type": "string",
                "enum": ["projectile", "install", "effect", "hazard", "unknown"]
              },
              "owner": {
                "type": "string"
              },
              "position": {
                "$ref": "#/$defs/vector2"
              }
            }
          }
        },
        "stage": {
          "type": "object"
        },
        "history": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "$ref": "#/$defs/history_entry"
          }
        }
      }
    },
    "legal_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "payload_spec", "supports"],
        "properties": {
          "action": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "payload_spec": {
            "anyOf": [
              {
                "type": "object",
                "maxProperties": 0
              },
              {
                "$ref": "#/$defs/parameter_descriptor"
              }
            ]
          },
          "prediction_spec": {
            "$ref": "#/$defs/parameter_descriptor"
          },
          "payload_schema": {
            "type": "object",
            "additionalProperties": true
          },
          "supports": {
            "type": "object",
            "additionalProperties": false,
            "required": ["di", "feint", "reverse", "prediction"],
            "properties": {
              "di": {
                "type": "boolean"
              },
              "feint": {
                "type": "boolean"
              },
              "reverse": {
                "type": "boolean"
              },
              "prediction": {
                "type": "boolean"
              }
            }
          },
          "damage": {
            "type": "number"
          },
          "startup_frames": {
            "type": "integer",
            "minimum": 0
          },
          "range": {
            "type": "number"
          },
          "meter_cost": {
            "type": "integer",
            "minimum": 0
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "trace_seed": {
      "type": "integer",
      "minimum": 0
    },
    "game_version": {
      "type": "string",
      "minLength": 1
    },
    "mod_version": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "ruleset_id": {
      "type": "string",
      "minLength": 1
    },
    "prompt_version": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "vector2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "history_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["turn_id"],
      "properties": {
        "turn_id": {
          "type": "integer",
          "minimum": 0
        },
        "game_tick": {
          "type": "integer",
          "minimum": 0
        },
        "player_id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "was_fallback": {
          "type": "boolean"
        },
        "p1_action": {
          "type": "string",
          "minLength": 1
        },
        "p2_action": {
          "type": "string",
          "minLength": 1
        },
        "p1_was_fallback": {
          "type": "boolean"
        },
        "p2_was_fallback": {
          "type": "boolean"
        },
        "p1_hp": {
          "type": "integer"
        },
        "p2_hp": {
          "type": "integer"
        },
        "p1_pos": {
          "$ref": "#/$defs/vector2"
        },
        "p2_pos": {
          "$ref": "#/$defs/vector2"
        },
        "p1_hp_delta": {
          "type": "integer"
        },
        "p2_hp_delta": {
          "type": "integer"
        },
        "p1_outcome": {
          "type": "string",
          "enum": ["hit", "blocked", "whiffed", "clashed", "grabbed", "dodged", "combo", "neutral"]
        },
        "p2_outcome": {
          "type": "string",
          "enum": ["hit", "blocked", "whiffed", "clashed", "grabbed", "dodged", "combo", "neutral"]
        }
      }
    },
    "parameter_descriptor": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "array",
            "boolean",
            "direction",
            "enemy",
            "integer",
            "number",
            "object",
            "self",
            "string",
            "vector2"
          ]
        },
        "additionalProperties": {
          "type": "boolean"
        },
        "choices": {
          "type": "array"
        },
        "const": true,
        "default": true,
        "description": {
          "type": "string"
        },
        "enum": {
          "type": "array"
        },
        "example": true,
        "items": {
          "$ref": "#/$defs/parameter_descriptor"
        },
        "maximum": {
          "type": "number"
        },
        "maxItems": {
          "type": "integer",
          "minimum": 0
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0
        },
        "minimum": {
          "type": "number"
        },
        "minItems": {
          "type": "integer",
          "minimum": 0
        },
        "minLength": {
          "type": "integer",
          "minimum": 0
        },
        "properties": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/parameter_descriptor"
          }
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "semantic_hint": {
          "type": "string"
        },
        "ui_kind": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}
