{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DecisionRequest v1",
  "description": "Canonical turn request emitted by the mod at an actionable decision point.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "match_id",
    "turn_id",
    "player_id",
    "deadline_ms",
    "state_hash",
    "legal_actions_hash",
    "decision_type",
    "observation",
    "legal_actions"
  ],
  "properties": {
    "match_id": {
      "type": "string",
      "minLength": 1
    },
    "turn_id": {
      "type": "integer",
      "minimum": 0
    },
    "player_id": {
      "type": "string",
      "minLength": 1
    },
    "deadline_ms": {
      "type": "integer",
      "minimum": 1
    },
    "state_hash": {
      "type": "string",
      "minLength": 1
    },
    "legal_actions_hash": {
      "type": "string",
      "minLength": 1
    },
    "decision_type": {
      "type": "string",
      "enum": ["turn_action"]
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tick",
        "frame",
        "active_player",
        "fighters",
        "objects",
        "stage",
        "history"
      ],
      "properties": {
        "tick": {
          "type": "integer",
          "minimum": 0
        },
        "frame": {
          "type": "integer",
          "minimum": 0
        },
        "active_player": {
          "type": "string",
          "minLength": 1
        },
        "fighters": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "character",
              "hp",
              "max_hp",
              "meter",
              "burst",
              "position",
              "velocity",
              "facing",
              "current_state",
              "combo_count",
              "hitstun",
              "hitlag"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "character": {
                "type": "string",
                "minLength": 1
              },
              "hp": {
                "type": "integer"
              },
              "max_hp": {
                "type": "integer",
                "minimum": 1
              },
              "meter": {
                "type": "integer",
                "minimum": 0
              },
              "burst": {
                "type": "integer",
                "minimum": 0
              },
              "position": {
                "$ref": "#/$defs/vector2"
              },
              "velocity": {
                "$ref": "#/$defs/vector2"
              },
              "facing": {
                "type": "string",
                "minLength": 1
              },
              "current_state": {
                "type": "string",
                "minLength": 1
              },
              "combo_count": {
                "type": "integer",
                "minimum": 0
              },
              "hitstun": {
                "type": "integer",
                "minimum": 0
              },
              "hitlag": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "objects": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "stage": {
          "type": "object"
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "legal_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "payload_spec", "supports"],
        "properties": {
          "action": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "payload_spec": {
            "type": "object",
            "additionalProperties": true
          },
          "supports": {
            "type": "object",
            "additionalProperties": false,
            "required": ["di", "feint", "reverse"],
            "properties": {
              "di": {
                "type": "boolean"
              },
              "feint": {
                "type": "boolean"
              },
              "reverse": {
                "type": "boolean"
              }
            }
          },
          "damage": {
            "type": "number"
          },
          "startup_frames": {
            "type": "integer",
            "minimum": 0
          },
          "range": {
            "type": "number"
          },
          "meter_cost": {
            "type": "integer",
            "minimum": 0
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "trace_seed": {
      "type": "integer",
      "minimum": 0
    },
    "game_version": {
      "type": "string",
      "minLength": 1
    },
    "mod_version": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "ruleset_id": {
      "type": "string",
      "minLength": 1
    },
    "prompt_version": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "vector2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    }
  }
}
