{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daemon Runtime Config v1",
  "description": "Versioned daemon-side runtime configuration with env-backed policy credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version"],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "auth_secret_env_var": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Environment variable name containing the shared secret for handshake authentication. When set, clients must send the correct auth_token in the hello payload."
        }
      }
    },
    "decision_timeout_ms": {
      "type": "integer",
      "minimum": 1
    },
    "fallback_mode": {
      "type": "string",
      "enum": ["safe_continue", "heuristic_guard", "last_valid_replayable"]
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "events": {
          "type": "boolean"
        },
        "prompts": {
          "type": "boolean"
        },
        "raw_provider_payloads": {
          "type": "boolean"
        }
      }
    },
    "policy_mapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "p1": {
          "type": "string",
          "minLength": 1
        },
        "p2": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policies": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["provider"],
        "properties": {
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "model": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "prompt_version": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "credential_env_var": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "temperature": {
            "type": ["number", "null"]
          },
          "max_tokens": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "options": {
            "type": "object"
          }
        }
      }
    },
    "character_selection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["mirror", "assigned", "random_from_pool"]
        },
        "assignments": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "p1": {
              "type": ["string", "null"],
              "minLength": 1
            },
            "p2": {
              "type": ["string", "null"],
              "minLength": 1
            }
          }
        },
        "pool": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "tournament": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "single_match",
            "side_swapped_pair",
            "round_robin",
            "double_round_robin"
          ]
        },
        "mirror_matches_first": {
          "type": "boolean"
        },
        "side_swap": {
          "type": "boolean"
        },
        "games_per_pair": {
          "type": "integer",
          "minimum": 1
        },
        "fixed_stage": {
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    },
    "trace_seed": {
      "type": "integer",
      "minimum": 0
    },
    "stage_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "match_options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "starting_hp": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 10000,
          "description": "Override starting and max HP for both fighters. Game default is 1500."
        }
      }
    },
    "replay_capture": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Record replay video via ffmpeg after match ends. Default: true."
        },
        "vm_machine": {
          "type": "string",
          "minLength": 1,
          "description": "OrbStack VM machine name. Default: ubuntu."
        },
        "display": {
          "type": "string",
          "minLength": 1,
          "description": "X display for recording. Default: :99."
        },
        "resolution": {
          "type": "string",
          "minLength": 1,
          "description": "Video resolution. Default: 1280x720."
        },
        "framerate": {
          "type": "integer",
          "minimum": 1,
          "description": "Video framerate. Default: 30."
        },
        "video_codec": {
          "type": "string",
          "minLength": 1,
          "description": "FFmpeg video codec. Default: libx264."
        },
        "preset": {
          "type": "string",
          "minLength": 1,
          "description": "FFmpeg encoding preset. Default: fast."
        }
      }
    }
  }
}
