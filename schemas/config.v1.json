{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConfigSnapshot v1",
  "description": "Wire-safe config snapshot shared during handshake and match setup.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_timeout_ms",
    "fallback_mode",
    "logging",
    "policy_mapping",
    "character_selection"
  ],
  "properties": {
    "decision_timeout_ms": {
      "type": "integer",
      "minimum": 1
    },
    "fallback_mode": {
      "type": "string",
      "enum": ["safe_continue", "heuristic_guard", "last_valid_replayable"]
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "required": ["events", "prompts", "raw_provider_payloads"],
      "properties": {
        "events": {
          "type": "boolean"
        },
        "prompts": {
          "type": "boolean"
        },
        "raw_provider_payloads": {
          "type": "boolean"
        }
      }
    },
    "policy_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p1", "p2"],
      "properties": {
        "p1": {
          "type": "string",
          "minLength": 1
        },
        "p2": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "character_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["mirror", "assigned", "random_from_pool"]
        },
        "assignments": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "p1": {
              "type": ["string", "null"],
              "minLength": 1
            },
            "p2": {
              "type": ["string", "null"],
              "minLength": 1
            }
          }
        },
        "pool": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "stage_id": {
      "type": ["string", "null"],
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "character_selection": {
            "properties": {
              "mode": {
                "const": "assigned"
              }
            },
            "required": ["mode"]
          }
        }
      },
      "then": {
        "properties": {
          "character_selection": {
            "required": ["assignments"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "character_selection": {
            "properties": {
              "mode": {
                "const": "random_from_pool"
              }
            },
            "required": ["mode"]
          }
        }
      },
      "then": {
        "properties": {
          "character_selection": {
            "required": ["pool"]
          }
        }
      }
    }
  ]
}
