{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hello v1",
  "description": "Initial handshake payload sent by the mod to the daemon.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "game_version",
    "mod_version",
    "schema_version",
    "supported_protocol_versions"
  ],
  "properties": {
    "game_version": {
      "type": "string",
      "minLength": 1
    },
    "mod_version": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "supported_protocol_versions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["v1"]
      }
    }
  }
}
