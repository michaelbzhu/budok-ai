{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ActionDecision v2",
  "description": "Structured action chosen by a daemon-side policy or fallback engine.",
  "type": "object",
  "additionalProperties": false,
  "required": ["match_id", "turn_id", "action", "data", "extra"],
  "properties": {
    "match_id": {
      "type": "string",
      "minLength": 1
    },
    "turn_id": {
      "type": "integer",
      "minimum": 0
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "data": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "extra": {
      "type": "object",
      "additionalProperties": false,
      "required": ["di", "feint", "reverse", "prediction"],
      "properties": {
        "di": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["x", "y"],
          "properties": {
            "x": {
              "type": "integer",
              "minimum": -100,
              "maximum": 100
            },
            "y": {
              "type": "integer",
              "minimum": -100,
              "maximum": 100
            }
          }
        },
        "feint": {
          "type": "boolean"
        },
        "reverse": {
          "type": "boolean"
        },
        "prediction": {
          "type": ["object", "null"],
          "additionalProperties": true
        }
      }
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "latency_ms": {
      "type": "integer",
      "minimum": 0
    },
    "tokens_in": {
      "type": "integer",
      "minimum": 0
    },
    "tokens_out": {
      "type": "integer",
      "minimum": 0
    },
    "reasoning": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "fallback_reason": {
      "type": "string",
      "enum": [
        "timeout",
        "disconnect",
        "malformed_output",
        "illegal_output",
        "stale_response"
      ]
    }
  }
}
