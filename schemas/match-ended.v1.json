{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MatchEnded v1",
  "description": "End-of-match summary emitted by the mod once the game resolves.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "match_id",
    "winner",
    "end_reason",
    "total_turns",
    "end_tick",
    "end_frame",
    "errors"
  ],
  "properties": {
    "match_id": {
      "type": "string",
      "minLength": 1
    },
    "winner": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "end_reason": {
      "type": "string",
      "minLength": 1
    },
    "total_turns": {
      "type": "integer",
      "minimum": 0
    },
    "end_tick": {
      "type": "integer",
      "minimum": 0
    },
    "end_frame": {
      "type": "integer",
      "minimum": 0
    },
    "replay_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
