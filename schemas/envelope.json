{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Envelope v1",
  "description": "Versioned transport envelope shared by all daemon and mod messages.",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "version", "ts", "payload"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "hello",
        "hello_ack",
        "decision_request",
        "action_decision",
        "event",
        "match_ended",
        "config"
      ]
    },
    "version": {
      "type": "string",
      "const": "v1"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    }
  }
}
