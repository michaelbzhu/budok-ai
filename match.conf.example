# match.conf — end-to-end match configuration
#
# Copy this file to match.conf (or any name) and pass it to run_match.sh:
#   scripts/run_match.sh match.conf
#
# Lines starting with # are comments. Blank lines are ignored.
# All values are KEY=VALUE pairs (no spaces around =).

# --- OrbStack VM settings ---

# OrbStack VM machine name
VM_NAME=ubuntu

# Path to the game inside the VM
VM_GAME_DIR=/home/nlevine/games/yomi

# Xvfb display number (must match what Xvfb is started with)
VM_DISPLAY=:99

# Xvfb resolution
VM_RESOLUTION=1280x720

# --- Daemon config ---

# Path to the daemon runtime config JSON (relative to repo root or absolute)
DAEMON_CONFIG=daemon/config/llm_v_llm.json

# Override daemon listen port (leave empty to use config file value)
DAEMON_PORT=

# Override log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Replay recording (true/false)
RECORD_REPLAY=true

# --- Mod networking ---

# How to resolve the bridge IP for the mod to reach the daemon:
#   auto   — detect from ifconfig bridge100 (recommended)
#   manual — use the BRIDGE_IP value below
BRIDGE_IP_MODE=auto

# Manual bridge IP (only used when BRIDGE_IP_MODE=manual)
BRIDGE_IP=192.168.139.3

# --- Environment ---

# Path to .env file for API keys (relative to repo root or absolute)
ENV_FILE=.env
