# YOMI Hustle LLM Arena — environment variable template
#
# Copy this file to .env and fill in the values for provider-backed policies.
# The daemon reads credentials from environment variables referenced by
# credential_env_var in each policy config entry.
#
# Baseline policies (baseline/random, baseline/block_always, etc.) do not
# require any credentials.

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...

# Optional: real-provider smoke test
# Set YOMI_SMOKE_PROVIDER to one of: anthropic, openai, openrouter
# Then run: uv run pytest tests/daemon/test_real_provider_smoke.py -v
# YOMI_SMOKE_PROVIDER=anthropic
