{
  "version": "v1",
  "transport": {
    "host": "0.0.0.0",
    "port": 8765
  },
  "decision_timeout_ms": 120000,
  "fallback_mode": "safe_continue",
  "logging": {
    "events": true,
    "prompts": true,
    "raw_provider_payloads": true
  },
  "policy_mapping": {
    "p1": "openai/gpt-5.4",
    "p2": "openai/gpt-5.5"
  },
  "policies": {
    "openai/gpt-5.4": {
      "provider": "openrouter",
      "model": "openai/gpt-5.4",
      "prompt_version": "strategic_v1",
      "credential_env_var": "OPENROUTER_API_KEY",
      "temperature": 0.7,
      "max_tokens": 4096,
      "options": {
        "response_parser": {
          "enable_correction_retry": true,
          "max_correction_retries": 1
        }
      }
    },
    "openai/gpt-5.5": {
      "provider": "openrouter",
      "model": "gpt-5.5",
      "prompt_version": "strategic_v1",
      "credential_env_var": "OPENROUTER_API_KEY",
      "temperature": 0.7,
      "max_tokens": 4096,
      "options": {
        "response_parser": {
          "enable_correction_retry": true,
          "max_correction_retries": 1
        }
      }
    }
  },
  "character_selection": {
    "mode": "llm_choice"
  },
  "trace_seed": 1,
  "stage_id": "training_room",
  "match_options": {
    "starting_hp": 750
  }
}
