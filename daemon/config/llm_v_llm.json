{
  "version": "v1",
  "transport": {
    "host": "0.0.0.0",
    "port": 8765
  },
  "decision_timeout_ms": 30000,
  "fallback_mode": "safe_continue",
  "logging": {
    "events": true,
    "prompts": true,
    "raw_provider_payloads": true
  },
  "policy_mapping": {
    "p1": "anthropic/claude-sonnet",
    "p2": "anthropic/claude-sonnet"
  },
  "policies": {
    "anthropic/claude-sonnet": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
      "prompt_version": "strategic_v1",
      "credential_env_var": "ANTHROPIC_API_KEY",
      "temperature": 0.7,
      "max_tokens": 512,
      "options": {
        "response_parser": {
          "enable_correction_retry": true,
          "max_correction_retries": 1
        }
      }
    }
  },
  "character_selection": {
    "mode": "assigned",
    "assignments": {"p1": "Cowboy", "p2": "Cowboy"}
  },
  "trace_seed": 1,
  "stage_id": "training_room",
  "match_options": {
    "starting_hp": 1000
  }
}
